# OPTIONAL FILE. With `--auto-cookie` you do NOT need this — the cookie is
# harvested by Playwright and cached automatically. Only use .env if you want to:
#   (a) paste a cookie manually (skip Playwright), or (b) override the User-Agent.
#
# NOTE: if TOKPED_COOKIE is set here it OVERRIDES --auto-cookie (unless you also
# pass --refresh-cookie). For pure auto mode, leave it blank/absent.
#
# Manual capture: DevTools > Network > any graphql request > Request Headers > cookie.
# Cookies expire — refresh when you get 403.

TOKPED_COOKIE=

# Optional: override the User-Agent (default is a recent desktop Chrome UA).
TOKPED_USER_AGENT=

# --- VPS runner: pull the authenticated cookie from the local auth service ---
# Base URL of the home auth service (keep it on a PRIVATE tunnel, e.g. Tailscale).
TOKPED_CRED_URL=
TOKPED_CRED_TOKEN=

# --- Local auth service (auth_service.py --serve): shared bearer token ---
# Must match TOKPED_CRED_TOKEN above. Without it the endpoint is UNAUTHENTICATED.
TOKPED_AUTH_TOKEN=
