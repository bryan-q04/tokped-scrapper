# =============================================================================
# PRIMARY PATH (recommended): static identity — no cookie, no auth service.
# =============================================================================
# Tokopedia's search returns the curated result set (real IQOS/TEREA, no
# "Terea Homeware" noise) when the request carries the logged-in ACCOUNT identity
# via the user_id param + Tkpd-Userid / Bd-Device-Id headers. These are stable
# identifiers, NOT session tokens — they don't expire on a timer, so you set them
# once and no cookie/tunnel/auth-service is needed.
#
# Capture once from a browser logged into the (burner) account:
#   DevTools > Network > the SearchProductV5Query request
#     - Payload  > variables.params : user_id=...  &  user_districtId=...
#     - Headers  > Request Headers  : Bd-Device-Id: ...
# Verify with:  python src/check_auth.py   (should print real-terea ~= page size)

TOKPED_USER_ID=
TOKPED_DEVICE_ID=
TOKPED_DISTRICT_ID=

# Optional: override the X-Version header (Tokopedia frontend build id) or the UA.
# Defaults are fine; only touch these if a scrape starts getting rejected.
TOKPED_X_VERSION=
TOKPED_USER_AGENT=

# --- Web UI (the `web` container): token to protect POST /api/run ---
# If unset, anyone who can reach the site can trigger scrapes. Set a secret.
TOKPED_WEB_TOKEN=

# =============================================================================
# FALLBACK PATH (optional): session cookie via the home auth service.
# =============================================================================
# Only needed if Tokopedia ever changes their API to require a real session again.
# Leave ALL of these blank while the identity path above works — the big cookie
# combined with the identity headers actually gets HTTP/2-reset, so don't set it
# unless you're deliberately using the cookie fallback (then also pass --no-cookie
# off / set no TOKPED_USER_ID).
TOKPED_COOKIE=
TOKPED_CRED_URL=
TOKPED_CRED_TOKEN=
TOKPED_AUTH_TOKEN=
